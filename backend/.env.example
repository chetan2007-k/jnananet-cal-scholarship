PORT=5000
AWS_REGION=ap-south-1
MODEL_ID=amazon.titan-text-lite-v1
# Optional: comma-separated origins (for S3/CloudFront frontend domains)
# CORS_ORIGIN=https://your-frontend-domain.com,http://localhost:5173

# Optional for /api/upload S3 integration
# S3_BUCKET=your-s3-bucket-name

# Password reset email configuration (Gmail + App Password)
SMTP_USER=jnananet.team@gmail.com
EMAIL_PASS=your_gmail_app_password
SMTP_APP_PASSWORD=your-gmail-app-password
ADMIN_NOTIFICATION_EMAIL=jnananet.team@gmail.com

# Frontend URL used in reset email links
FRONTEND_RESET_BASE_URL=http://localhost:5173
